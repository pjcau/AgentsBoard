# AgentsBoard — Build .deb package for Debian/Ubuntu
# Usage:
#   docker build -f Dockerfile.deb -t agentsboard-deb-builder .
#   docker run --rm -v $(pwd)/release-artifacts:/out agentsboard-deb-builder

FROM swift:6.0-noble AS builder

RUN apt-get update && apt-get install -y \
    libsqlite3-dev wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# GRDB requires SQLite with SQLITE_ENABLE_SNAPSHOT
RUN wget -q "https://www.sqlite.org/2024/sqlite-autoconf-3460100.tar.gz" \
    && tar xf sqlite-autoconf-3460100.tar.gz \
    && cd sqlite-autoconf-3460100 \
    && CFLAGS="-DSQLITE_ENABLE_SNAPSHOT -O2" \
       ./configure --prefix=/usr --libdir=/usr/lib/$(dpkg-architecture -qDEB_HOST_MULTIARCH) --disable-static \
    && make -j$(nproc) && make install \
    && cd .. && rm -rf sqlite-autoconf-* && ldconfig

WORKDIR /app
COPY Package.swift Package.resolved* ./
COPY Sources/ Sources/
COPY Tests/ Tests/

RUN swift build --product AgentsBoardServer -c release --static-swift-stdlib

# --- Package stage ---
FROM debian:bookworm-slim AS packager

RUN apt-get update && apt-get install -y dpkg-dev && rm -rf /var/lib/apt/lists/*

ARG VERSION=0.8.0
ARG ARCH=arm64

# Build .deb directory structure
WORKDIR /deb
RUN mkdir -p \
    agentsboard_${VERSION}_${ARCH}/DEBIAN \
    agentsboard_${VERSION}_${ARCH}/usr/bin \
    agentsboard_${VERSION}_${ARCH}/usr/lib/systemd/system \
    agentsboard_${VERSION}_${ARCH}/usr/share/agentsboard \
    agentsboard_${VERSION}_${ARCH}/etc/agentsboard

# Copy binary from builder
COPY --from=builder /app/.build/*-unknown-linux-gnu/release/AgentsBoardServer \
    agentsboard_${VERSION}_${ARCH}/usr/bin/agentsboard-server

# Control file
RUN cat > agentsboard_${VERSION}_${ARCH}/DEBIAN/control << EOF
Package: agentsboard
Version: ${VERSION}
Section: devel
Priority: optional
Architecture: ${ARCH}
Depends: libsqlite3-0
Maintainer: pjcau <pjonny@gmail.com>
Description: AI Agent Mission Control
 Fleet management dashboard for AI coding agents.
 HTTP + WebSocket API server on localhost:19850.
 Supports Claude Code, Codex, Aider, and Gemini.
Homepage: https://github.com/pjcau/AgentsBoard
EOF

# Post-install script
RUN cat > agentsboard_${VERSION}_${ARCH}/DEBIAN/postinst << 'EOF'
#!/bin/bash
set -e
# Create config directory
mkdir -p /etc/agentsboard
# Enable and start service if systemd is running
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload
    systemctl enable agentsboard.service
    echo "AgentsBoard installed. Start with: sudo systemctl start agentsboard"
    echo "Or run directly: agentsboard-server"
fi
EOF
RUN chmod 755 agentsboard_${VERSION}_${ARCH}/DEBIAN/postinst

# Pre-remove script
RUN cat > agentsboard_${VERSION}_${ARCH}/DEBIAN/prerm << 'EOF'
#!/bin/bash
set -e
if [ -d /run/systemd/system ]; then
    systemctl stop agentsboard.service 2>/dev/null || true
    systemctl disable agentsboard.service 2>/dev/null || true
fi
EOF
RUN chmod 755 agentsboard_${VERSION}_${ARCH}/DEBIAN/prerm

# Systemd service file
RUN cat > agentsboard_${VERSION}_${ARCH}/usr/lib/systemd/system/agentsboard.service << EOF
[Unit]
Description=AgentsBoard API Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/agentsboard-server
Environment=AGENTSBOARD_HOST=127.0.0.1
Environment=AGENTSBOARD_PORT=19850
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

# Default config
RUN cat > agentsboard_${VERSION}_${ARCH}/etc/agentsboard/config.yml << EOF
# AgentsBoard Server Configuration
host: "127.0.0.1"
port: 19850
theme: dark
EOF

# Set permissions
RUN chmod 755 agentsboard_${VERSION}_${ARCH}/usr/bin/agentsboard-server

# Build the .deb
RUN dpkg-deb --build agentsboard_${VERSION}_${ARCH}

# Output stage — copy .deb to /out
FROM scratch
COPY --from=packager /deb/*.deb /
