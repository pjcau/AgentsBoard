# AgentsBoard Server — Debian runtime image
# Build: docker build -f Dockerfile.debian -t agentsboard-debian .
# Run:   docker run -p 19850:19850 agentsboard-debian

FROM swift:6.0-noble AS builder

RUN apt-get update && apt-get install -y \
    libsqlite3-dev wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# GRDB requires SQLite with SQLITE_ENABLE_SNAPSHOT
RUN wget -q "https://www.sqlite.org/2024/sqlite-autoconf-3460100.tar.gz" \
    && tar xf sqlite-autoconf-3460100.tar.gz \
    && cd sqlite-autoconf-3460100 \
    && CFLAGS="-DSQLITE_ENABLE_SNAPSHOT -O2" \
       ./configure --prefix=/usr --libdir=/usr/lib/$(dpkg-architecture -qDEB_HOST_MULTIARCH) --disable-static \
    && make -j$(nproc) && make install \
    && cd .. && rm -rf sqlite-autoconf-* && ldconfig

WORKDIR /app
COPY Package.swift Package.resolved* ./
COPY Sources/ Sources/
COPY Tests/ Tests/

RUN swift build --product AgentsBoardServer -c release --static-swift-stdlib

# --- Debian runtime ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsqlite3-0 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/lib/*-linux-gnu/libsqlite3.so* /usr/lib/
COPY --from=builder /app/.build/*-unknown-linux-gnu/release/AgentsBoardServer /usr/local/bin/agentsboard-server

WORKDIR /app
EXPOSE 19850
ENV AGENTSBOARD_HOST=0.0.0.0
ENTRYPOINT ["agentsboard-server"]
