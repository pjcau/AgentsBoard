# AgentsBoard Desktop — Linux GUI app (.deb with Tauri + embedded server)
#
# Builds a standalone desktop application for Linux that includes:
# - Tauri native window (GTK/WebKit) with the React web frontend
# - AgentsBoardServer binary bundled as sidecar (auto-launched)
#
# Usage:
#   # ARM64 (default on Apple Silicon / Raspberry Pi / AWS Graviton)
#   docker build -f Dockerfile.desktop -o release-artifacts .
#
#   # Intel x86_64
#   docker build -f Dockerfile.desktop --platform linux/amd64 -o release-artifacts/x86 .
#
# Install on Debian/Ubuntu:
#   sudo dpkg -i agentsboard-desktop_0.8.0_arm64.deb
#   agentsboard-desktop

# ==============================================================================
# Stage 1: Build Swift server (static binary)
# ==============================================================================
FROM swift:6.0-noble AS swift-builder

RUN apt-get update && apt-get install -y \
    libsqlite3-dev wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# SQLite with SQLITE_ENABLE_SNAPSHOT (required by GRDB)
RUN wget -q "https://www.sqlite.org/2024/sqlite-autoconf-3460100.tar.gz" \
    && tar xf sqlite-autoconf-3460100.tar.gz \
    && cd sqlite-autoconf-3460100 \
    && CFLAGS="-DSQLITE_ENABLE_SNAPSHOT -O2" \
       ./configure --prefix=/usr --libdir=/usr/lib/$(dpkg-architecture -qDEB_HOST_MULTIARCH) --disable-static \
    && make -j$(nproc) && make install \
    && cd .. && rm -rf sqlite-autoconf-* && ldconfig

WORKDIR /app
COPY Package.swift Package.resolved* ./
COPY Sources/ Sources/
COPY Tests/ Tests/

RUN swift build --product AgentsBoardServer -c release --static-swift-stdlib

# ==============================================================================
# Stage 2: Build web frontend
# ==============================================================================
FROM node:20-slim AS web-builder

WORKDIR /web
COPY web/package.json web/package-lock.json* ./
RUN npm ci --ignore-scripts 2>/dev/null || npm install
COPY web/ .
RUN npm run build

# ==============================================================================
# Stage 3: Build Tauri desktop app
# ==============================================================================
FROM ubuntu:24.04 AS tauri-builder

# Tauri build dependencies (GTK3, WebKit, etc.)
RUN apt-get update && apt-get install -y \
    build-essential curl wget file \
    libwebkit2gtk-4.1-dev libgtk-3-dev libayatana-appindicator3-dev \
    librsvg2-dev libssl-dev pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Tauri CLI
RUN cargo install tauri-cli

# Copy web dist from web-builder
COPY --from=web-builder /web/dist /app/web/dist

# Copy Tauri project
WORKDIR /app/tauri
COPY tauri/Cargo.toml tauri/Cargo.lock tauri/build.rs ./
COPY tauri/src/ src/
COPY tauri/icons/ icons/
COPY tauri/tauri.conf.json .

# Fix frontendDist path for Docker build context
RUN sed -i 's|"../web/dist"|"/app/web/dist"|g' tauri.conf.json

# Build Tauri (produces .deb in target/release/bundle/deb/)
RUN cargo tauri build --bundles deb 2>&1 || true

# Also build AppImage
RUN cargo tauri build --bundles appimage 2>&1 || true

# ==============================================================================
# Stage 4: Assemble final .deb with server sidecar
# ==============================================================================
FROM debian:bookworm-slim AS assembler

RUN apt-get update && apt-get install -y dpkg-dev && rm -rf /var/lib/apt/lists/*

ARG VERSION=0.8.0

WORKDIR /deb

# Copy Tauri .deb if it was built
COPY --from=tauri-builder /app/tauri/target/release/bundle/deb/*.deb /tmp/tauri.deb

# Extract Tauri .deb to inject server binary
RUN dpkg-deb -R /tmp/tauri.deb pkg/ \
    # Copy server binary into the package
    && mkdir -p pkg/usr/lib/agentsboard/ \
    # Update control file
    && sed -i 's/^Depends:.*/Depends: libsqlite3-0, libwebkit2gtk-4.1-0, libgtk-3-0, libayatana-appindicator3-1/' pkg/DEBIAN/control \
    && sed -i "s/^Version:.*/Version: ${VERSION}/" pkg/DEBIAN/control

# Copy Swift server binary into the package
COPY --from=swift-builder /app/.build/*-unknown-linux-gnu/release/AgentsBoardServer \
    pkg/usr/lib/agentsboard/agentsboard-server

RUN chmod 755 pkg/usr/lib/agentsboard/agentsboard-server

# Create wrapper script that starts server + app
RUN cat > pkg/usr/bin/agentsboard-desktop << 'WRAPPER'
#!/bin/bash
# Start AgentsBoardServer in background
/usr/lib/agentsboard/agentsboard-server &
SERVER_PID=$!
trap "kill $SERVER_PID 2>/dev/null" EXIT

# Wait for server to be ready
for i in $(seq 1 30); do
    curl -s http://localhost:19850/api/v1/fleet/stats > /dev/null 2>&1 && break
    sleep 0.2
done

# Launch the Tauri GUI
exec /usr/bin/agentsboard "$@"
WRAPPER
RUN chmod 755 pkg/usr/bin/agentsboard-desktop

# Create .desktop entry for Linux app launcher
RUN mkdir -p pkg/usr/share/applications && \
    cat > pkg/usr/share/applications/agentsboard.desktop << 'DESKTOP'
[Desktop Entry]
Name=AgentsBoard
Comment=AI Agent Mission Control
Exec=agentsboard-desktop
Icon=agentsboard
Type=Application
Categories=Development;
Terminal=false
DESKTOP

# Rebuild the .deb
RUN ARCH=$(dpkg --print-architecture) && \
    dpkg-deb --build pkg agentsboard-desktop_${VERSION}_${ARCH}.deb

# ==============================================================================
# Output
# ==============================================================================
FROM scratch
COPY --from=assembler /deb/agentsboard-desktop_*.deb /
