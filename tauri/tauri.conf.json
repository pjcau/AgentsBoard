{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-conf/main/schema.json",
  "productName": "AgentsBoard",
  "version": "0.8.0",
  "identifier": "com.agentsboard.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "AgentsBoard",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "AgentsBoard"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:19850 http://localhost:19850"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libsqlite3-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "wix": {}
    }
  }
}
