# AgentsBoard Qt Desktop — Multi-stage Linux build
# Stage 1: Build Swift Core as shared library
# Stage 2: Build Qt app linking Core (same Swift base for runtime libs)
# Stage 3: Package into .deb
#
# Build: docker build -f Dockerfile.qt -t agentsboard-qt .
# Extract deb: docker build -f Dockerfile.qt --target=package --output=. .

FROM swift:6.0-noble AS swift-builder

RUN apt-get update && apt-get install -y \
    libsqlite3-dev wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# GRDB requires SQLite with SQLITE_ENABLE_SNAPSHOT
RUN wget -q "https://www.sqlite.org/2024/sqlite-autoconf-3460100.tar.gz" \
    && tar xf sqlite-autoconf-3460100.tar.gz \
    && cd sqlite-autoconf-3460100 \
    && CFLAGS="-DSQLITE_ENABLE_SNAPSHOT -O2" \
       ./configure --prefix=/usr --libdir=/usr/lib/$(dpkg-architecture -qDEB_HOST_MULTIARCH) --disable-static \
    && make -j$(nproc) && make install \
    && cd .. && rm -rf sqlite-autoconf-* && ldconfig

WORKDIR /app
COPY Package.swift Package.resolved* ./
COPY Sources/ Sources/
COPY Tests/ Tests/

# Build CoreFFI as dynamic library
RUN swift build --product AgentsBoardCoreFFI -c release

# --- Stage 2: Build Qt App (same Swift base so runtime libs are available) ---
FROM swift:6.0-noble AS qt-builder

RUN apt-get update && apt-get install -y \
    qt6-base-dev qt6-declarative-dev \
    cmake ninja-build g++ \
    libgl1-mesa-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy Swift Core shared library, custom SQLite, and headers
COPY --from=swift-builder /app/.build/release/libAgentsBoardCoreFFI.so /usr/local/lib/
COPY --from=swift-builder /usr/lib/*-linux-gnu/libsqlite3.so* /usr/lib/x86_64-linux-gnu/
COPY Sources/CoreFFI/include/ /usr/local/include/
RUN ldconfig

# Copy Qt sources
COPY qt/ qt/

# Build Qt app
RUN cd qt && mkdir build && cd build \
    && cmake .. -DCMAKE_BUILD_TYPE=Release \
       -DCORE_FFI_LIB_DIR=/usr/local/lib \
       -DCORE_FFI_INCLUDE=/usr/local/include \
       -G Ninja \
    && ninja

# --- Stage 3: .deb package ---
FROM ubuntu:24.04 AS deb-builder

RUN apt-get update && apt-get install -y dpkg-dev && rm -rf /var/lib/apt/lists/*

ARG VERSION=0.9.0
ARG ARCH=amd64

WORKDIR /pkg

# Package structure
RUN mkdir -p deb/DEBIAN deb/usr/bin deb/usr/lib/agentsboard deb/usr/share/applications

COPY --from=qt-builder /app/qt/build/agentsboard-qt deb/usr/bin/
COPY --from=swift-builder /app/.build/release/libAgentsBoardCoreFFI.so deb/usr/lib/agentsboard/
COPY --from=swift-builder /usr/lib/*-linux-gnu/libsqlite3.so* deb/usr/lib/agentsboard/
COPY qt/packaging/linux/agentsboard.desktop deb/usr/share/applications/

# Wrapper script that sets LD_LIBRARY_PATH
RUN mv deb/usr/bin/agentsboard-qt deb/usr/lib/agentsboard/agentsboard-qt \
    && printf '#!/bin/sh\nexec /usr/lib/agentsboard/agentsboard-qt "$@"\n' > deb/usr/bin/agentsboard \
    && chmod +x deb/usr/bin/agentsboard

RUN cat > deb/DEBIAN/control <<EOF
Package: agentsboard
Version: ${VERSION}
Section: devel
Priority: optional
Architecture: ${ARCH}
Depends: libqt6core6, libqt6gui6, libqt6qml6, libqt6quick6, libqt6widgets6, libsqlite3-0
Maintainer: AgentsBoard <support@agentsboard.dev>
Description: AI Agent Mission Control — Desktop
 Fleet management, code review, and orchestration for AI coding agents.
 Native Qt 6 desktop application with embedded Swift Core.
EOF

RUN dpkg-deb --build deb agentsboard-desktop_${VERSION}_${ARCH}.deb

# Final output
FROM scratch AS package
COPY --from=deb-builder /pkg/*.deb /
